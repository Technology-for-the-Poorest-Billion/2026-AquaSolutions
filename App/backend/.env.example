# Copy to .env and fill in. .env is gitignored.

# Shared secret used by field sensors to authenticate against POST /ingest.
# Any random string; rotate if exposed.
DEVICE_SECRET=replace-me-with-a-long-random-string

# Path to the SQLite database file. Relative paths resolve to App/backend/.
DATABASE_PATH=data/water_safety.db

# Twilio Auth Token, from the Twilio console.
# Used to verify webhook signatures on POST /sms. Required for production;
# leave blank during local development if you want to skip signature checks
# (do NOT do this on any internet-reachable deployment).
TWILIO_AUTH_TOKEN=

# When false, /sms accepts unsigned requests (useful for curl-based local
# testing). MUST be true in any deployment Twilio talks to.
TWILIO_VALIDATE_SIGNATURES=false

# Public base URL Flask is reachable at, as Twilio sees it
# (e.g. https://abc123.ngrok.io). Needed by the signature validator
# to reconstruct the URL Twilio signed.
PUBLIC_BASE_URL=

# Flask server settings (local dev only)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
